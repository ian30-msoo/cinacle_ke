                          size: 12, color: AppColors.textMuted),
                      const SizedBox(width: 4),
                      Text(
                        item['date']!,
                        style: const TextStyle(fontSize: 12, color: AppColors.textMuted),
                      ),
                    ],
                  ),
                ],
              ),
            ),
          ],
        ),
      ),
    );
  }
}

