rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─────────────────────────────────────────────
    // LETS TALK MEDIA
    // Images and videos uploaded with posts
    // ─────────────────────────────────────────────

    match /lets_talk_media/{type}/{fileName} {
      // Anyone can view media (posts are public)
      allow read: if true;

      // Only signed-in users can upload
      // Images: max 10 MB | Videos: max 100 MB
      allow create: if request.auth != null
        && (
          // Image upload
          (type == 'images'
            && request.resource.contentType.matches('image/.*')
            && request.resource.size <= 10 * 1024 * 1024)
          ||
          // Video upload
          (type == 'videos'
            && request.resource.contentType.matches('video/.*')
            && request.resource.size <= 100 * 1024 * 1024)
        );

      // Only the file owner can delete
      // (Firebase Storage doesn't expose auth uid in metadata by default
      //  so we allow any signed-in user to delete for now —
      //  tighten this later by saving uid in customMetadata on upload)
      allow delete: if request.auth != null;

      // No updates (overwrite not needed — new file = new upload)
      allow update: if false;
    }

    // ─────────────────────────────────────────────
    // USER AVATARS (if needed later)
    // ─────────────────────────────────────────────

    match /user_avatars/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.contentType.matches('image/.*')
        && request.resource.size <= 5 * 1024 * 1024;
    }

    // Block everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
